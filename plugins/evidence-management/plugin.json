{
  "plugin": {
    "id": "evidence-management",
    "name": "Evidence Library",
    "version": "0.1.0",
    "type": "domain",
    "description": "Central evidence records with validation, validity windows, and reusable links across the workspace.",
    "vendor": "pymesec",
    "license": "AGPL-3.0-or-later"
  },
  "compatibility": {
    "core": "^0.1.0",
    "sdk": "^0.1.0"
  },
  "dependencies": [],
  "permissions": [
    {
      "key": "plugin.evidence-management.evidence.view",
      "label": "View evidence",
      "description": "View evidence records, their status, and linked work items.",
      "feature_area": "evidence",
      "operation": "view",
      "contexts": [
        "organization"
      ]
    },
    {
      "key": "plugin.evidence-management.evidence.manage",
      "label": "Manage evidence",
      "description": "Create, update, validate, and link evidence records.",
      "feature_area": "evidence",
      "operation": "manage",
      "contexts": [
        "organization"
      ]
    }
  ],
  "routes": [
    {
      "id": "evidence-management.web",
      "type": "web",
      "file": "routes/web.php",
      "middleware": [
        "web"
      ],
      "permission": "plugin.evidence-management.evidence.view"
    }
  ],
  "menus": [
    {
      "id": "plugin.evidence-management.root",
      "label_key": "plugin.evidence-management.nav.root",
      "route": "plugin.evidence-management.index",
      "icon": "binder",
      "order": 44,
      "permission": "plugin.evidence-management.evidence.view"
    }
  ],
  "migrations": [],
  "translations": {
    "default_locale": "en",
    "supported_locales": [
      "en",
      "es",
      "fr",
      "de"
    ],
    "path": "resources/lang"
  },
  "support": {
    "path": "resources/support",
    "supported_locales": [
      "en"
    ]
  },
  "lifecycle": {},
  "runtime": {
    "class": "PymeSec\\Plugins\\EvidenceManagement\\EvidenceManagementPlugin",
    "autoload": {
      "psr-4": {
        "PymeSec\\Plugins\\EvidenceManagement\\": "src"
      }
    }
  }
}
