{
  "plugin": {
    "id": "questionnaires",
    "name": "Questionnaires",
    "version": "0.1.0",
    "type": "domain",
    "description": "Shared questionnaire templates, subject-bound items, and answer semantics for reusable internal and external collection workflows.",
    "vendor": "pymesec",
    "license": "AGPL-3.0-or-later"
  },
  "compatibility": {
    "core": "^0.1.0",
    "sdk": "^0.1.0"
  },
  "dependencies": [],
  "permissions": [],
  "routes": [],
  "menus": [],
  "migrations": [],
  "translations": {
    "default_locale": "en",
    "supported_locales": [
      "en",
      "es",
      "fr",
      "de"
    ],
    "path": "resources/lang"
  },
  "support": {
    "path": "resources/support",
    "supported_locales": [
      "en",
      "es",
      "fr",
      "de"
    ]
  },
  "lifecycle": {},
  "runtime": {
    "class": "PymeSec\\Plugins\\Questionnaires\\QuestionnairesPlugin",
    "autoload": {
      "psr-4": {
        "PymeSec\\Plugins\\Questionnaires\\": "src"
      }
    }
  }
}
