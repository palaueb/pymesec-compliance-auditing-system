{
  "plugin": {
    "id": "identity-local",
    "name": "Identity Local",
    "version": "0.1.0",
    "type": "identity",
    "description": "Placeholder manifest for the local identity plugin skeleton.",
    "vendor": "pymesec",
    "license": "AGPL-3.0-or-later"
  },
  "compatibility": {
    "core": "^0.1.0",
    "sdk": "^0.1.0"
  },
  "dependencies": [],
  "permissions": [
    {
      "key": "plugin.identity-local.principals.view",
      "label": "View local identity principals",
      "description": "View principals managed by the local identity plugin.",
      "feature_area": "principals",
      "operation": "view",
      "contexts": [
        "organization"
      ]
    }
  ],
  "routes": [],
  "menus": [],
  "migrations": [],
  "translations": {
    "default_locale": "en",
    "supported_locales": [
      "en",
      "es",
      "fr",
      "de"
    ],
    "path": "resources/lang"
  },
  "lifecycle": {},
  "runtime": {
    "class": "PymeSec\\Plugins\\IdentityLocal\\IdentityLocalPlugin",
    "autoload": {
      "psr-4": {
        "PymeSec\\Plugins\\IdentityLocal\\": "src"
      }
    }
  }
}
